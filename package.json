{
  "name": "screen-share-app",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "ts-node --project tsconfig.server.json server.ts",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File start.ps1",
    "start:media": "ts-node --project tsconfig.server.json media-server.ts",
    "build": "next build",
    "start": "cross-env NODE_ENV=production ts-node --project tsconfig.server.json server.ts",
    "lint": "eslint"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "hls.js": "^1.6.16",
    "next": "16.2.7",
    "node-media-server": "^2.7.0",
    "peerjs": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-media-server": "^2.3.7",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
